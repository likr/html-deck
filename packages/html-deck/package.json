{
  "name": "html-deck",
  "version": "1.0.0-alpha.1",
  "description": "An Agent-First WebComponents Slideshow Library",
  "type": "module",
  "main": "dist/html-deck.js",
  "module": "dist/html-deck.js",
  "exports": {
    ".": {
      "development": "./src/html-deck.js",
      "default": "./dist/html-deck.js"
    },
    "./css": {
      "development": "./src/html-deck.css",
      "default": "./dist/html-deck.css"
    },
    "./theme-corporate": "./src/themes/html-deck.theme-corporate.css",
    "./theme-dark": "./src/themes/html-deck.theme-dark.css",
    "./theme-dotted": "./src/themes/html-deck.theme-dotted.css",
    "./theme-neon": "./src/themes/html-deck.theme-neon.css",
    "./theme-serif": "./src/themes/html-deck.theme-serif.css",
    "./theme-warm": "./src/themes/html-deck.theme-warm.css",
    "./presenter": {
      "development": "./src/html-deck-presenter.js",
      "default": "./dist/html-deck-presenter.js"
    },
    "./presenter/css": {
      "development": "./src/html-deck-presenter.css",
      "default": "./dist/html-deck-presenter.css"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0"
  }
}
